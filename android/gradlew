#!/bin/sh
#
# Gradle start up script for UN*X
#
# This script is generated by Gradle.
#
# To customize the behaviour of this script, create a file in the same directory
# named "gradlew.properties" and it will be sourced by this script.
#
# If you are using a custom Gradle distribution, specify the URL in the
# "distributionUrl" property in gradle/wrapper/gradle-wrapper.properties.
#
# Copyright 2012-2020 the Gradle authors.
#
# Licensed under the Apache License, Version 2.0 (the "License");
# you may not use this file except in compliance with the License.
# You may obtain a copy of the License at
#
#      http://www.apache.org/licenses/LICENSE-2.0
#
# Unless required by applicable law or agreed to in writing, software
# distributed under the License is distributed on an "AS IS" BASIS,
# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
# See the License for the specific language governing permissions and
# limitations under the License.

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD="maximum"

warn () {
    echo "$*"
}

die () {
    echo
    echo "$*"
    echo
    exit 1
}

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$(uname)" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if [ "$cygwin" = "false" -a "$darwin" = "false" -a "$nonstop" = "false" ] ; then
    MAX_FD_LIMIT=$(ulimit -H -n)
    if [ $? -eq 0 ] ; then
        if [ "$MAX_FD" = "maximum" -o "$MAX_FD" = "max" ] ; then
            MAX_FD="$MAX_FD_LIMIT"
        fi
        ulimit -n $MAX_FD 2>/dev/null
        if [ $? -ne 0 ] ; then
            warn "Could not set maximum file descriptor limit: $MAX_FD"
        fi
    fi
fi

# For Darwin, add options to specify how the application appears in the dock
if [ "$darwin" = "true" ] ; then
    GRADLE_OPTS="$GRADLE_OPTS \"-Xdock:name=$APP_NAME\" \"-Xdock:icon=$APP_HOME/media/gradle.icns\""
fi

# For Cygwin or MSYS, switch paths to Windows format before running java
if [ "$cygwin" = "true" -o "$msys" = "true" ] ; then
    APP_HOME=$(cygpath --path --mixed "$APP_HOME")
    CLASSPATH=$(cygpath --path --mixed "$CLASSPATH")
    JAVACMD=$(cygpath --unix "$JAVACMD")

    # We build the pattern for arguments to be converted via cygpath
    ROOTDIRSRAW=$(cygpath --path --unix "$APP_HOME/..")
    # Convert to pattern
    for ROOTDIR in $ROOTDIRSRAW ; do
        ROOTDIR=$(cygpath --path --mixed "$ROOTDIR")
        ROOTDIRS="${ROOTDIRS} $ROOTDIR"
    done
fi

# Split up the JVM_OPTS And GRADLE_OPTS values into an array, following the shell quoting rules
# This is needed because we must allow for the possibility of multiple JVM_OPTS/GRADLE_OPTS
# values which could contain spaces.
eval set -- "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS"

# Now we process the arguments
while [ $# -gt 0 ] ; do
    case "$1" in
        -h|--help)
            echo "Usage: $APP_BASE_NAME [OPTIONS...] [TASKS...]"
            echo ""
            echo "Options:"
            echo "  -h, --help           Prints this help message"
            echo "  -v, --version        Prints version information"
            echo "  --offline            Run without network access"
            echo "  --no-daemon          Do not use Gradle daemon"
            echo "  -Dprop=value         Set system property"
            echo "  -Pprop=value         Set project property"
            echo "  -b, --build-file     Specify build file"
            echo "  -c, --settings-file  Specify settings file"
            echo "  -p, --project-dir    Specify project directory"
            echo ""
            echo "For more information, see https://docs.gradle.org/current/userguide/command_line_interface.html"
            exit 0
            ;;
        --version)
            exec "$JAVACMD" -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain --version
            ;;
        *)
            break
            ;;
    esac
    shift
done

# Escape application args
save () {
    for i do printf %s\\n "$i" | sed "s/'/'\\\\\\\\''/g;1s/^/'/;\$s/\$/' \\\\/" ; done
    echo " "
}

APP_ARGS=$(save "$@")

# Collect all arguments for the java command, following the shell quoting rules.
eval set -- $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS "$APP_ARGS"

# by default we should be in the correct project dir, but when run from
# Finder on Mac OS X, the working directory is the user's home directory,
# so change directory to the project directory.
cd "$APP_HOME"

# Add -Dorg.gradle.appname=$APP_BASE_NAME to make logging nicer
exec "$JAVACMD" "$@" -classpath "$CLASSPATH" -Dorg.gradle.appname="$APP_BASE_NAME" org.gradle.wrapper.GradleWrapperMain "$@"
